# ==================== REQUIRED - Supabase ====================
# أنشئ مشروع مجاني على https://supabase.com
# شغّل SQL الموجود في supabase-schema.sql في Supabase SQL Editor
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service Role Key (للمصادقة عبر API Key في MCP) — من Supabase > Settings > API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==================== OPTIONAL - Dev API Keys ====================
# مفاتيح API مسموحة للتطوير (بدون Supabase auth)
# RISE_ALLOWED_API_KEYS=rise_xxxxx

# ==================== OPTIONAL - AI Coach ====================
# لو عايز ميزة AI Coach تشتغل
# BIGMODEL_API_KEY=your-api-key

# ==================== ملاحظات ====================
# 1. قاعدة البيانات هي Supabase (PostgreSQL) - مش SQLite
# 2. بعد ما تعمل clone، شغّل الأوامر دي:
#    bun install
#    bun run dev
# 3. لازم تعمل deploy لـ supabase-schema.sql في Supabase SQL Editor