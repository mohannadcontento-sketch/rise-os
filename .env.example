# ==================== REQUIRED ====================
# قاعدة البيانات (SQLite) - غيّر المسار حسب مكان المشروع عندك
DATABASE_URL="file:./db/custom.db"

# ==================== OPTIONAL - تسجيل الدخول ====================
# لو عايز تعمل تسجيل دخول بحسابات Supabase
# أنشئ مشروع مجاني على https://supabase.com وضع البيانات دي
# NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ==================== OPTIONAL - AI Coach ====================
# لو عايز ميزة AI Coach تشتغل
# BIGMODEL_API_KEY="your-api-key"

# ==================== ملاحظات ====================
# 1. المشروع يشتغل كويس من غير Supabase - استخدم وضع الزائر (Guest Mode)
# 2. AI Coach فيه fallback يعني يشتغل حتى لو مفيش API key
# 3. بعد ما تعمل clone، شغّل الأوامر دي:
#    bun install
#    bun run db:push
#    bun run dev