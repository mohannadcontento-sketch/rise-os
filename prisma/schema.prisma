generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USER & GAMIFICATION ====================

model User {
  id            String    @id @default(cuid())
  name          String    @default("مستخدم")
  email         String    @unique
  avatar        String?
  level         Int       @default(1)
  xp            Int       @default(0)
  xpToNextLevel Int       @default(100)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  totalFocusMin Int       @default(0)
  totalTasksDone Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tasks         Task[]
  projects      Project[]
  goals         Goal[]
  habits        Habit[]
  journals      Journal[]
  morningLogs   MorningLog[]
  healthLogs    HealthLog[]
  financeRecords FinanceRecord[]
  books         Book[]
  knowledge     KnowledgeItem[]
  focusSessions FocusSession[]
  achievements  UserAchievement[]
  dailyScores   DailyScore[]
  settings      UserSettings?
  plannerItems  PlannerItem[]
}

model UserAchievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId     String
  badgeName   String
  badgeIcon   String
  badgeDesc   String
  earnedAt    DateTime @default(now())
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme             String   @default("system")
  language          String   @default("ar")
  wakeUpTime        String   @default("06:00")
  sleepTime         String   @default("22:00")
  focusDuration     Int      @default(50)
  dailyWaterGoal    Int      @default(8)
  dailyReadingGoal  Int      @default(30)
  weeklyExerciseGoal Int     @default(5)
  notifications     Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DailyScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  score     Float    @default(0)
  morningScore Float @default(0)
  taskScore     Float @default(0)
  habitScore    Float @default(0)
  focusScore    Float @default(0)
  healthScore   Float @default(0)
  journalScore  Float @default(0)
  createdAt DateTime @default(now())
}

// ==================== TASKS & PROJECTS ====================

model Task {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("todo") // todo, in_progress, done, cancelled
  priority    String   @default("medium") // low, medium, high, urgent
  label       String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDate     String?
  dueTime     String?
  isRecurring Boolean  @default(false)
  recurringPattern String?
  estimatedMin Int?
  xpReward    Int      @default(10)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subtasks    SubTask[]
  dependsOn   String?   // comma-separated task IDs
  order       Int      @default(0)
}

model SubTask {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String   @default("#059669")
  icon        String?
  progress    Float    @default(0)
  status      String   @default("active") // active, completed, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
}

// ==================== GOALS ====================

model Goal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  vision      String?
  why         String?
  type        String   @default("quarterly") // annual, quarterly, monthly, weekly, daily
  progress    Float    @default(0)
  status      String   @default("active") // active, completed, abandoned
  deadline    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  milestones  Milestone[]
}

model Milestone {
  id          String   @id @default(cuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

// ==================== HABITS ====================

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  icon        String?
  color       String   @default("#059669")
  frequency   String   @default("daily") // daily, weekly, monthly, custom
  targetCount Int      @default(1)
  reminderTime String?   // HH:MM format
  xpReward    Int      @default(15)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        HabitLog[]
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date        String
  completed   Boolean  @default(false)
  count       Int      @default(1)
  createdAt   DateTime @default(now())
}

// ==================== MORNING ROUTINE ====================

model MorningLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String
  score       Float    @default(0)
  completedItems String // JSON array
  totalItems  Int
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ==================== JOURNAL ====================

model Journal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String
  content     String   @default("")
  gratitude   String?
  wins        String?
  challenges  String?
  mood        Int?
  energy      Int?
  ideas       String?
  tomorrowPlan String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== DEEP WORK ====================

model FocusSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration    Int      // minutes planned
  actualMin   Int      @default(0)
  type        String   @default("pomodoro") // pomodoro, deep50, deep90, deep120
  notes       String?
  taskId      String?
  completed   Boolean  @default(false)
  startedAt   DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ==================== HEALTH ====================

model HealthLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String
  sleepHours  Float?
  sleepQuality Int?
  waterGlasses Int?
  steps       Int?
  calories    Int?
  weight      Float?
  mood        Int?
  energy      Int?
  exerciseType String?
  exerciseMin  Int?
  exerciseNote String?
  createdAt   DateTime @default(now())
}

// ==================== FINANCE ====================

model FinanceRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // income, expense, savings, investment, subscription
  category    String?
  description String
  amount      Float
  date        String
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ==================== READING & LEARNING ====================

model Book {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  author      String?
  type        String   @default("book") // book, article, course, video
  status      String   @default("reading") // want_to_read, reading, completed, abandoned
  currentPage Int      @default(0)
  totalPages  Int?
  notes       String?
  highlights  String?  // JSON
  favoriteQuote String?
  rating      Int?
  coverUrl    String?
  progress    Float    @default(0)
  startDate   String?
  endDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== SECOND BRAIN ====================

model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   @default("note") // project, knowledge, idea, resource, bookmark, inspiration, research, design_ref
  title       String
  content     String   @default("")
  folder      String?
  tags        String?  // JSON
  source      String?
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== DAILY PLANNER ====================

model PlannerItem {
  id        String   @id @default(cuid())
  userId    String
  date      String
  section   String
  time      String?
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, section, order])
}